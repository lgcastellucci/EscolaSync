<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EscolaSync.MainPage"
             Title="EscolaSync">

    <Grid RowDefinitions="Auto,Auto,*,Auto" Padding="20" RowSpacing="12">

        <!-- STATUS DE AUTENTICAÇÃO -->
        <Frame Grid.Row="0" Padding="12" CornerRadius="10"
               BackgroundColor="{Binding AuthStatusColor}">
            <Grid ColumnDefinitions="Auto,*">
                <Label Grid.Column="0" Text="●" FontSize="18" VerticalOptions="Center"
                       TextColor="{Binding AuthDotColor}"/>
                <Label Grid.Column="1" Text="{Binding AuthStatusText}"
                       FontSize="13" Margin="8,0,0,0"
                       VerticalOptions="Center" TextColor="White" FontAttributes="Bold"/>
            </Grid>
        </Frame>

        <!-- BOTÕES -->
        <HorizontalStackLayout Grid.Row="1" Spacing="10" HorizontalOptions="Center">
            <Button Text="🔐 Autenticar Drive"
                    Command="{Binding AuthCommand}"
                    BackgroundColor="#1E40AF" TextColor="White"
                    CornerRadius="8" FontSize="13"/>
            <Button Text="📤 Enviar Agora"
                    Command="{Binding SyncCommand}"
                    IsEnabled="{Binding CanSync}"
                    BackgroundColor="#059669" TextColor="White"
                    CornerRadius="8" FontSize="13"/>
        </HorizontalStackLayout>

        <!-- LOG VISUAL — cada passo aparece aqui -->
        <Frame Grid.Row="2" Padding="0" CornerRadius="10"
               BackgroundColor="#0F172A" HasShadow="False">
            <Grid RowDefinitions="Auto,*">
                <Label Grid.Row="0" Text="📋 Log de execução"
                       FontSize="12" TextColor="#94A3B8"
                       Padding="12,8" FontAttributes="Bold"/>
                <ScrollView Grid.Row="1" x:Name="LogScroll">
                    <VerticalStackLayout x:Name="LogStack" Padding="12,0,12,12" Spacing="4"
                                        BindableLayout.ItemsSource="{Binding LogEntries}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Frame Padding="8,5" CornerRadius="6"
                                       BackgroundColor="{Binding BgColor}" HasShadow="False">
                                    <Grid ColumnDefinitions="Auto,Auto,*">
                                        <Label Grid.Column="0" Text="{Binding Icon}"
                                               FontSize="13" VerticalOptions="Center"/>
                                        <Label Grid.Column="1" Text="{Binding Time}"
                                               FontSize="10" TextColor="#64748B"
                                               VerticalOptions="Center" Margin="6,0"/>
                                        <Label Grid.Column="2" Text="{Binding Message}"
                                               FontSize="12" TextColor="{Binding TextColor}"
                                               VerticalOptions="Center" LineBreakMode="WordWrap"/>
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </ScrollView>
            </Grid>
        </Frame>

        <!-- PROGRESSO -->
        <VerticalStackLayout Grid.Row="3" Spacing="4">
            <ProgressBar Progress="{Binding Progress}"
                         ProgressColor="#60A5FA"
                         BackgroundColor="#1E3A8A"
                         HeightRequest="8"/>
            <Label Text="{Binding ProgressText}"
                   FontSize="11" TextColor="#94A3B8"
                   HorizontalOptions="Center"/>
        </VerticalStackLayout>

    </Grid>
</ContentPage>
